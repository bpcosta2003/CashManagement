# ─── Frontend (Vite) ───────────────────────────────────────────────
# Copy to .env.local and fill in. Without these the app works in
# local-only mode (everything in localStorage, no login UI).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Liga a feature de Análise IA no frontend. Se "false" ou ausente, o
# card de IA não aparece. Os secrets do backend ainda precisam estar
# configurados (próxima seção) pra IA realmente funcionar.
VITE_AI_ENABLED=false


# ─── Backend (Vercel Functions — server-side only) ─────────────────
# Estes secrets NUNCA são expostos ao bundle do frontend. Configure no
# painel do Vercel (Settings → Environment Variables) ou em .env.local
# pra desenvolvimento local com `vercel dev`.

# Chave da Anthropic (Console → API Keys). Obrigatória pra IA.
ANTHROPIC_API_KEY=

# Modelo Claude usado nas análises. Default: claude-haiku-4-5-20251001
# (mais barato da família 4.x). Pra qualidade superior use:
# claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Service role key do Supabase (Settings → API → service_role).
# Necessária pra Function escrever em ai_usage / ai_analysis_cache
# bypassando RLS de forma segura no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# URL do projeto Supabase (mesma do VITE_SUPABASE_URL, mas sem o prefixo
# VITE_ porque é lida no servidor).
SUPABASE_URL=

# Limite máximo de gasto da feature por mês de calendário, em centavos
# de dólar. Quando o total ultrapassa este valor, novas análises são
# bloqueadas com 503 até virar o mês. Default: 2000 ($20).
AI_MONTHLY_BUDGET_CENTS=2000

# Limite de análises por usuário por mês de calendário. Cache hits não
# contam. Default: 3.
AI_USER_MONTHLY_LIMIT=3


# ─── Email (Resend) — notificações automáticas ─────────────────────
# Cron diário às 12 UTC (9h BRT) envia emails de resumo no último dia
# útil do mês e lembrete de metas no 1º dia. Opt-in pelo usuário em
# Preferências → Lembretes → Notificações por email.

# API key do Resend (resend.com → API Keys). Plano free: 100 emails/dia,
# 3.000/mês.
RESEND_API_KEY=

# Remetente. Em testes use "onboarding@resend.dev" (só envia pro email
# da sua conta Resend). Em produção, verifique seu domínio no Resend
# e use algo como "Cash Management <noreply@seudominio.com>".
FROM_EMAIL=Cash Management <onboarding@resend.dev>

# URL do app, usada nos CTAs dos emails.
APP_URL=https://cashmanagement.vercel.app

# Secret pra autenticar invocações do cron. O Vercel injeta automatica-
# mente no header Authorization: Bearer <CRON_SECRET>. Defina qualquer
# string aleatória aqui (ex.: 32 caracteres). Sem isso, o endpoint do
# cron fica público — use sempre em produção.
CRON_SECRET=
